generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String?  @unique
  phone     String?  @unique
  password  String
  role      String   @default("user")
  devices   Device[]
  createdAt DateTime @default(now())
permission UserPermission?
  glucoseReadings GlucoseReading[]
workoutSessions WorkoutSession[]

  doctorAccess UserDoctorAccess[]
}


model Device {
  id        String   @id @default(uuid())
  name      String
  type      String
  userId    String
  createdAt DateTime @default(now())
  workoutSessions WorkoutSession[]

   snapshot  DeviceVitalsSnapshot?   // ✅ FIXED


  user User @relation(fields: [userId], references: [id])
   glucoseReadings GlucoseReading[]
  telemetry Telemetry[]

  // ECG
  ecg        ECG[]
  ecgSummaries ECGSummary[]

  // SpO2
  spo2Samples SpO2Sample[] @relation("DeviceSpO2Samples")
  sleepSessions SleepSession[]
  bloodPressures BloodPressure[]
 stress Stress[]

temperatureSamples TemperatureSample[]

 
}

model Telemetry {
  id       String @id @default(uuid())
  deviceId String
  device   Device @relation(fields: [deviceId], references: [id])

  heartRate Int
  steps     Int
  battery   Int

  workoutSessionId String?
  workoutSession   WorkoutSession? @relation(fields: [workoutSessionId], references: [id])

  measuredAt DateTime   // ← REAL time from device
  createdAt  DateTime @default(now()) // server insert time
}







model Alert {
  id       String @id @default(uuid())
  userId   String
  deviceId String

  metric   String // HEART_RATE, BATTERY, OFFLINE
  value    Int
  severity String // INFO, WARNING, CRITICAL
  message  String

  acknowledged Boolean @default(false)

  createdAt DateTime @default(now())
}


model ECG {
  id           String   @id @default(uuid())
  deviceId     String

  lead         String   @default("I")
  unit         String   @default("mV")
  samplingRate Int
  paperSpeed   Int      @default(25)
  gain         Int      @default(10)

  signal       Float[]
  durationMs   Int
  quality      Int      @default(50)

measuredAt DateTime

  createdAt    DateTime @default(now())

  device Device @relation(fields: [deviceId], references: [id])
  @@index([deviceId, measuredAt])
}





model ECGSummary {
  id        String   @id @default(uuid())
  deviceId  String
  window    String
  avgHR     Int
  minHR     Int
  maxHR     Int
  rrVar     Float
  pvcCount  Int
  quality   Int
  createdAt DateTime @default(now())
measuredAt DateTime
  device Device @relation(fields: [deviceId], references: [id])

  @@index([deviceId, measuredAt])
}

model SpO2Sample {
  id        String   @id @default(uuid())
  deviceId  String
  value     Int
  perfusion Int?
  createdAt DateTime @default(now())

  device Device @relation("DeviceSpO2Samples", fields: [deviceId], references: [id])

  @@index([deviceId, createdAt])
}
model SleepSession {
  id        String   @id @default(uuid())
  deviceId String

  startTime DateTime
  endTime   DateTime

  totalMinutes Int

  deepMinutes  Int?
  lightMinutes Int?
  remMinutes   Int?
  awakeMinutes Int?

  avgHR   Int?
  avgSpO2 Int?

  createdAt DateTime @default(now())

  device Device @relation(fields: [deviceId], references: [id])

  @@unique([deviceId, startTime])
  @@index([deviceId, startTime])
}

model BloodPressure {
  id        String   @id @default(uuid())
  deviceId String

  systolic  Int   // SYS (e.g. 120)
  diastolic Int   // DIA (e.g. 80)
  pulse     Int?  // optional heart rate during BP reading

  measuredAt DateTime

  createdAt DateTime @default(now())

  device Device @relation(fields: [deviceId], references: [id])

  @@index([deviceId, measuredAt])
}


model TemperatureSample {
  id        String   @id @default(uuid())
  deviceId String

  value     Float    // body temperature in °C (ex: 36.5, 37.2)
  unit      String   @default("C") // C or F

  measuredAt DateTime
  createdAt  DateTime @default(now())

  device Device @relation(fields: [deviceId], references: [id])

  @@index([deviceId, measuredAt])
}

model UserDoctorAccess {
  id         String   @id @default(uuid())
  userId     String
  doctorId   String
  doctorName String   // ADD THIS
  access     String   @default("FULL")
  status     String   @default("ACTIVE")
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, doctorId])
}

model UserPermission {
  id              String  @id @default(uuid())
  userId          String  @unique
  allowAlerts     Boolean @default(true)
  allowBackground Boolean @default(true)
  allowAnalytics  Boolean @default(true)
  autoConnect     Boolean @default(true)

  user User @relation(fields: [userId], references: [id])
}



model Stress {
  id        String   @id @default(uuid())
  deviceId  String
  value     Int
  level     String?   // ← make optional
  source    String?   // optional too
  createdAt DateTime @default(now())
measuredAt DateTime
  device Device @relation(fields: [deviceId], references: [id])
    @@index([deviceId, measuredAt])
}

model WorkoutSession {
  id        String   @id @default(uuid())
  userId    String
  deviceId  String

  type      String
  status    String   @default("ACTIVE") // ACTIVE | ENDED | PAUSED

  startTime DateTime
  endTime   DateTime?
  duration  Int?

  // 🔴 ADD THESE
  lastTelemetryAt DateTime?
  autoEnded       Boolean @default(false)
  endReason       String? // NO_TELEMETRY | HR_ZERO | MAX_DURATION | MANUAL

  avgHR     Int?
  maxHR     Int?
  calories  Int?

  zone1 Int @default(0)
  zone2 Int @default(0)
  zone3 Int @default(0)
  zone4 Int @default(0)
  zone5 Int @default(0)

  stepsDelta Int @default(0)

  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  device Device @relation(fields: [deviceId], references: [id])

  telemetry Telemetry[]
  sets      WorkoutSet[]
}


model Exercise {
  id          String   @id @default(uuid())
  name        String
  muscleGroup String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt @default(now())

  sets        WorkoutSet[]
}

model WorkoutSet {
  id         String @id @default(uuid())
  sessionId  String
  exerciseId String

  reps     Int?
  weight   Float?
  duration Int?

  createdAt DateTime @default(now())

  session  WorkoutSession @relation(fields: [sessionId], references: [id])
  exercise Exercise       @relation(fields: [exerciseId], references: [id])
}

model GlucoseReading {
  id          String   @id @default(uuid())
  deviceId    String
  userId      String
  glucose     Float
  unit        String   @default("mg/dL")
  mealContext String?
  source      String?  // MANUAL | DEVICE | CGM
  notes       String?
  measuredAt  DateTime
  createdAt   DateTime @default(now())

  device Device @relation(fields: [deviceId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([deviceId, measuredAt])
}

model DeviceVitalsSnapshot {
  deviceId String @id

  heartRate Int?
  heartRateAt DateTime?

  spo2 Int?
  spo2At DateTime?

  systolic Int?
  diastolic Int?
  bpAt DateTime?

  temperature Float?
  temperatureAt DateTime?

  stress Int?
  stressAt DateTime?

  updatedAt DateTime @updatedAt

  device Device @relation(fields: [deviceId], references: [id])
}
